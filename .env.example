#################################################
# MMOS
#################################################

APP_NAME=MusabMine OS
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000
LOG_LEVEL=info

#################################################
# DATABASE
#################################################

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mmos
DATABASE_USER=change_me
DATABASE_PASSWORD=change_me

#################################################
# REDIS
#################################################

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

#################################################
# AUTHENTICATION
#################################################

JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

#################################################
# SOCKET.IO
#################################################

SOCKET_PORT=3001

#################################################
# AI
#################################################

AI_PROVIDER=change_me
AI_API_KEY=change_me

#################################################
# STORAGE
#################################################

UPLOAD_PATH=storage/uploads

#################################################
# TIMEZONE
#################################################

TZ=UTC
